# Vercel env (Frontend + API + Telegram webhook handler).
# Set these in Vercel Project → Settings → Environment Variables.

DATABASE_URL=
REDIS_URL=
BOT_TOKEN=

# Public URL of the deployed app (set to the same domain you're deploying to):
WEB_APP_URL=https://your-app.vercel.app

# Webhook mode for Telegram updates:
TELEGRAM_UPDATE_MODE=webhook

# Optional but recommended: validates Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=

# Telegram auth replay window (seconds)
TELEGRAM_AUTH_MAX_AGE_SECONDS=300

# Platform fee (percent)
PLATFORM_FEE_PERCENT=10

# Optional AI (Groq) for /api/ai/chat only
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

