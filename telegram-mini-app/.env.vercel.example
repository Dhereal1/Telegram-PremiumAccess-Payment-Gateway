# Vercel env (Frontend + API + Telegram webhook handler).
# Set these in Vercel Project → Settings → Environment Variables.

DATABASE_URL=
REDIS_URL=
BOT_TOKEN=

# Public URL of the deployed app (set to the same domain you're deploying to):
WEB_APP_URL=https://your-app.vercel.app

# Optional but recommended: validates Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=

CHANNEL_ID=
CRON_SECRET=

# Platform fee (percent)
PLATFORM_FEE_PERCENT=10
# Platform wallet address to collect fees (enables split payments enforcement)
PLATFORM_WALLET_ADDRESS=

# TON Center (used by listener/verifier if running alongside this deploy)
TON_API_URL=https://toncenter.com/api/v2
TON_API_KEY=

# Optional AI (Groq) for /api/ai/chat only
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Frontend (Vite) — used in Admin Dashboard to generate bot deep links
VITE_BOT_USERNAME=tonpremium_access_bot
