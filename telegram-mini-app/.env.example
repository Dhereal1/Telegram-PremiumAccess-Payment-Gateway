# Copy to `.env` and fill in values (do not commit `.env`).

DATABASE_URL=
REDIS_URL=

BOT_TOKEN=
# Optional (used for deep links; can be discovered via getMe in some flows)
BOT_USERNAME=

# Public HTTPS URL for the Mini App (Cloudflare/Ngrok/Vercel). Must end with `/` or without; both ok.
WEB_APP_URL=

# TON Center
TON_API_URL=https://toncenter.com/api/v2
TON_API_KEY=

# Legacy single-tenant fallbacks (optional when using multi-tenant groups/admin wallets)
TON_RECEIVER_ADDRESS=
TON_PRICE_TON=0.1

# Platform fee percent (integer or decimal string)
PLATFORM_FEE_PERCENT=10

# Telegram auth window (seconds)
TELEGRAM_AUTH_MAX_AGE_SECONDS=300

# Local dev update mode:
# - `webhook`: setWebhook to WEB_APP_URL/api/telegram/webhook
# - `polling`: deleteWebhook and use getUpdates polling (only one instance can poll)
TELEGRAM_UPDATE_MODE=webhook

# Optional: set DNS servers to reduce Windows ISP DNS issues (comma-separated)
# DNS_SERVERS=1.1.1.1,8.8.8.8

# Optional AI (Groq). If not set, AI features auto-disable silently.
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

