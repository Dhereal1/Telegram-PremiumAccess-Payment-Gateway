# Copy to `.env` and fill in values (do not commit `.env`).

DATABASE_URL=
REDIS_URL=

BOT_TOKEN=

# Public HTTPS URL for the Mini App (Cloudflare/Ngrok/Vercel). Must end with `/` or without; both ok.
WEB_APP_URL=

# Optional but recommended: validates Telegram webhook requests (setWebhook secret_token)
TELEGRAM_WEBHOOK_SECRET=

# TON Center
TON_API_URL=https://toncenter.com/api/v2
TON_API_KEY=

# Platform fee percent (integer or decimal string)
PLATFORM_FEE_PERCENT=10
# Platform fee collection wallet (required if you want on-chain fee enforcement via split payments)
PLATFORM_WALLET_ADDRESS=

# Optional: shared secret for internal/admin endpoints when not called by Vercel Cron
CRON_SECRET=

# Optional AI (Groq). If not set, AI features auto-disable silently.
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
