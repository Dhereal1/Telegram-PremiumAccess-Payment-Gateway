# Workers env (run on laptop/VPS with PM2).
# Copy to `.env` on the worker machine OR load into PM2 env another way.
# Do not commit real secrets.

DATABASE_URL=
REDIS_URL=

BOT_TOKEN=
# Stable Mini App URL (your Vercel production domain once deployed):
WEB_APP_URL=https://your-app.vercel.app

# Telegram mode:
# - Workers do NOT need polling; they only call Bot API.
TELEGRAM_UPDATE_MODE=webhook

# TON Center
TON_API_URL=https://toncenter.com/api/v2
TON_API_KEY=

# Optional AI (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Optional: DNS override for flaky networks
# DNS_SERVERS=1.1.1.1,8.8.8.8

