# Workers env (run on laptop/VPS with PM2).
# Copy to `.env` on the worker machine OR load into PM2 env another way.
# Do not commit real secrets.

DATABASE_URL=
REDIS_URL=

BOT_TOKEN=
# Stable Mini App URL (your Vercel production domain once deployed):
WEB_APP_URL=https://your-app.vercel.app

# TON Center
TON_API_URL=https://toncenter.com/api/v2
TON_API_KEY=

# Optional AI (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Platform fee enforcement (optional; if set, verifier requires a matching fee payment into this wallet)
PLATFORM_WALLET_ADDRESS=
PLATFORM_FEE_PERCENT=10

# Used for invites/kicks
CHANNEL_ID=
